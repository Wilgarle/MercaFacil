.idea/
*.iml
.vscode/
.classpath
.project
.settings/

# Logs y archivos temporales
*.log
*.tmp
*.temp
hs_err_pid*

# Archivos del sistema operativo
.DS_Store
Thumbs.db

# Ignorar la carpeta de base de datos local si existiera
/mysql_data/
