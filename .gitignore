# Archivos compilados y empaquetados (binarios)
*.class
*.jar
*.war
*.ear

# Carpetas de construccion de NetBeans
build/
dist/
target/

# Configuraciones privadas de NetBeans (contiene rutas locales de tu PC)
nbproject/private/
nbproject/project.xml.bak
nbbuild/

